# Copy to .env and adjust as needed: cp .env.example .env

# MLflow tracking server
# NOTE: macOS Control Center (AirPlay Receiver) occupies port 5000 -> use 5001 locally.
# In Docker Compose this is set per-service to http://mlflow:5000 (in-network).
MLFLOW_TRACKING_URI=http://localhost:5001

# Model registry
MODEL_NAME=ChurnModel
MODEL_STAGE=Production

# Drift detection thresholds
DRIFT_PSI_THRESHOLD=0.2
DRIFT_KS_PVALUE_THRESHOLD=0.05

# Data paths
REFERENCE_DATA_PATH=data/reference/reference_data.parquet
RAW_DATA_PATH=data/raw/WA_Fn-UseC_-Telco-Customer-Churn.csv
LIVE_DATA_PATH=data/live/recorded_features.jsonl
DRIFT_HISTORY_PATH=data/live/drift_history.parquet

# Logging — set to false for JSON logs (production), true for console logs (dev)
DEV_MODE=true
